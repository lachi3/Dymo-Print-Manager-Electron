{
  "name": "dymo-print-manager-electron",
  "version": "1.0.0",
  "productName": "DYMO Print Manager",
  "description": "Desktop wrapper for Dymo Print Manager",
  "main": "electron/main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac --config.directories.output=release/mac",
    "dist:win": "electron-builder --win --x64 --config.directories.output=release/win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.stc.dymoprintmanager",
    "productName": "Dymo Print Manager",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ],
          "icon": "assets/dymo_ico.png"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        "dmg"
      ]
    }
  }
}
